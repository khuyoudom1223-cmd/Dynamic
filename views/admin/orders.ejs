<%- include('../partials/head', { title }) %>
  <%- include('../partials/navbar') %>

    <main class="shell section">
      <div class="section-head" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <h1 style="margin:0;">Orders</h1>
        <!-- Live indicator -->
        <span id="live-badge" style="
        display:inline-flex;align-items:center;gap:6px;
        background:#d1fae5;color:#065f46;
        padding:4px 12px;border-radius:999px;font-size:0.78rem;font-weight:700;
      ">
          <span id="live-dot"
            style="width:8px;height:8px;border-radius:50%;background:#10b981;animation:pulse 1.5s infinite;"></span>
          LIVE
        </span>
        <span id="last-updated" style="font-size:0.78rem;color:#94a3b8;margin-left:auto;"></span>
        <a href="/admin" class="btn-inline">Back to Dashboard</a>
      </div>

      <div id="orders-status-bar" style="
      margin:16px 0 8px;padding:10px 16px;border-radius:10px;
      background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;
      font-size:0.85rem;font-weight:600;display:none;
    " id="orders-toast"></div>

      <div class="card table-wrap">
        <table id="orders-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Email</th>
              <th>Product</th>
              <th>Total Price</th>
              <th>Status</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="orders-tbody">
            <% if (!orders.length) { %>
              <tr>
                <td colspan="8" style="text-align:center;color:#94a3b8;">No orders yet.</td>
              </tr>
              <% } %>
                <% orders.forEach((order)=> { %>
                  <tr id="order-row-<%= order.id %>" data-status="<%= order.status %>">
                    <td>
                      <%= order.id %>
                    </td>
                    <td>
                      <%= order.user ? order.user.name : '-' %>
                    </td>
                    <td>
                      <%= order.user ? order.user.email : '-' %>
                    </td>
                    <td>
                      <% if (order.product) { %>
                        <%= order.product.name || order.product.title %>
                          <% } else if (order.category) { %>
                            Category: <%= order.category.name %>
                              <% } else { %>
                                -
                                <% } %>
                    </td>
                    <td>$<%= Number(order.total_price).toFixed(2) %>
                    </td>
                    <td>
                      <span class="status-pill status-<%= order.status %>" id="status-pill-<%= order.id %>">
                        <%= order.status.toUpperCase() %>
                      </span>
                    </td>
                    <td>
                      <%= new Date(order.created_at).toLocaleString() %>
                    </td>
                    <td>
                      <form action="/admin/orders/<%= order.id %>/status" method="post" class="inline-form">
                        <select name="status" class="status-select status-select-<%= order.status %>"
                          data-status-select>
                          <option value="pending" <%=order.status==='pending' ? 'selected' : '' %>>Pending</option>
                          <option value="paid" <%=order.status==='paid' ? 'selected' : '' %>>Paid</option>
                          <option value="cancelled" <%=order.status==='cancelled' ? 'selected' : '' %>>Cancelled
                          </option>
                        </select>
                        <button class="btn-inline" type="submit">Update</button>
                      </form>
                    </td>
                  </tr>
                  <% }) %>
          </tbody>
        </table>
      </div>
    </main>

    <%- include('../partials/footer') %>

      <style>
        @keyframes pulse {

          0%,
          100% {
            opacity: 1;
            transform: scale(1);
          }

          50% {
            opacity: 0.5;
            transform: scale(1.4);
          }
        }

        @keyframes rowFlash {
          0% {
            background: #d1fae5;
          }

          100% {
            background: transparent;
          }
        }

        .status-pill {
          display: inline-block;
          padding: 3px 10px;
          border-radius: 999px;
          font-size: 0.75rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.05em;
        }

        .status-pending {
          background: #fef3c7;
          color: #92400e;
        }

        .status-paid {
          background: #d1fae5;
          color: #065f46;
        }

        .status-cancelled,
        .status-failed {
          background: #fee2e2;
          color: #991b1b;
        }

        .row-updated {
          animation: rowFlash 1.5s ease-out forwards;
        }
      </style>

      <script>
        (function () {
          "use strict";

          // ── Track current order statuses from server-rendered HTML ────────────
          const knownStatuses = {};
          document.querySelectorAll("tr[id^='order-row-']").forEach(row => {
            const id = row.id.replace("order-row-", "");
            knownStatuses[id] = row.dataset.status;
          });

          let newPaidCount = 0;

          // ── Status pill HTML helper ───────────────────────────────────────────
          function statusPillHtml(status) {
            return `<span class="status-pill status-${status}">${status.toUpperCase()}</span>`;
          }

          // ── Action cell helper ───────────────────────────────────────────────
          function actionHtml(order) {
            return `
          <form action="/admin/orders/${order.id}/status" method="post" class="inline-form">
            <select name="status" class="status-select status-select-${order.status}" data-status-select>
              <option value="pending" ${order.status === 'pending' ? 'selected' : ''}>Pending</option>
              <option value="paid" ${order.status === 'paid' ? 'selected' : ''}>Paid</option>
              <option value="cancelled" ${order.status === 'cancelled' ? 'selected' : ''}>Cancelled</option>
            </select>
            <button class="btn-inline" type="submit">Update</button>
          </form>`;
          }

          // ── Show a toast banner at top of table ───────────────────────────────
          function showBanner(msg) {
            const bar = document.getElementById("orders-status-bar");
            bar.textContent = msg;
            bar.style.display = "block";
            setTimeout(() => { bar.style.display = "none"; }, 5000);
          }

          // ── Poll /admin/api/orders every 4 seconds ────────────────────────────
          async function poll() {
            try {
              const res = await fetch("/admin/api/orders", { cache: "no-store" });
              if (!res.ok) return;
              const data = await res.json();
              if (!data.ok) return;

              newPaidCount = 0;

              data.orders.forEach(order => {
                const prevStatus = knownStatuses[order.id];

                // New order row – inject it
                if (prevStatus === undefined) {
                  const tbody = document.getElementById("orders-tbody");
                  const tr = document.createElement("tr");
                  tr.id = `order-row-${order.id}`;
                  tr.dataset.status = order.status;
                  const productLabel = order.product
                    ? (order.product.name || order.product.title)
                    : order.category
                      ? `Category: ${order.category.name}`
                      : "-";

                  tr.innerHTML = `
                <td>${order.id}</td>
                <td>${order.user ? order.user.name : "-"}</td>
                <td>${order.user ? order.user.email : "-"}</td>
                <td>${productLabel}</td>
                <td>$${Number(order.total_price).toFixed(2)}</td>
                <td>${statusPillHtml(order.status)}</td>
                <td>${new Date(order.created_at).toLocaleString()}</td>
                <td>${actionHtml(order)}</td>`;
                  tbody.prepend(tr);
                  knownStatuses[order.id] = order.status;
                  return;
                }

                // Status changed
                if (prevStatus !== order.status) {
                  knownStatuses[order.id] = order.status;

                  const row = document.getElementById(`order-row-${order.id}`);
                  if (!row) return;

                  // Update status pill
                  const pill = document.getElementById(`status-pill-${order.id}`);
                  if (pill) {
                    pill.className = `status-pill status-${order.status}`;
                    pill.textContent = order.status.toUpperCase();
                  } else {
                    // Pill was server-rendered without an id — rebuild the cell
                    row.cells[5].innerHTML = statusPillHtml(order.status);
                  }

                  // Update action cell
                  row.cells[7].innerHTML = actionHtml(order);

                  // Flash the row green
                  row.classList.remove("row-updated");
                  void row.offsetWidth; // reflow to restart animation
                  row.classList.add("row-updated");

                  if (order.status === "paid") newPaidCount++;
                }
              });

              if (newPaidCount > 0) {
                showBanner(`✅ ${newPaidCount} order${newPaidCount > 1 ? "s" : ""} just updated to PAID automatically!`);
              }

              // Update last-refreshed timestamp
              document.getElementById("last-updated").textContent =
                "Last updated: " + new Date().toLocaleTimeString();

            } catch (err) {
              console.error("[Orders Polling] Error:", err);
            }
          }

          // Start immediately, then every 4 seconds
          poll();
          setInterval(poll, 4000);
        })();
      </script>