<%- include('../partials/head', { title }) %>
  <%- include('../partials/navbar') %>

    <main class="section" style="padding-top: 2rem;">
      <div style="width: min(1200px, 94vw); margin: 0 auto; display: flex; flex-direction: column; gap: 1.25rem;"
        class="dashboard-shell">
        <aside
          style="width: 100%; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);"
          class="dashboard-sidebar">
          <div style="padding: 1rem 1.25rem; border-bottom: 1px solid #f1f5f9;">
            <p
              style="margin: 0; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: #64748b; font-weight: 700;">
              Admin Panel</p>
            <h2 style="margin: 0.35rem 0 0 0; font-size: 1.1rem; color: #0f172a;">Dashboard</h2>
          </div>
          <div style="padding: 0.75rem;">
            <a href="/admin/products?action=add"
              style="display: block; text-align: center; background: #10b981; color: #fff; border-radius: 10px; padding: 0.55rem 0.75rem; font-weight: 700; text-decoration: none;">+
              Add Product</a>
          </div>
          <nav style="padding: 0 0.75rem 0.75rem 0.75rem; display: grid; gap: 0.35rem;">
            <a href="/admin"
              style="background: #4f46e5; color: #fff; padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; font-weight: 600;">Dashboard</a>
            <a href="/admin/users"
              style="background: #f8fafc; color: #334155; padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; font-weight: 600;">Users</a>
            <a href="/admin/categories"
              style="background: #f8fafc; color: #334155; padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; font-weight: 600;">Categories</a>
            <a href="/admin/products"
              style="background: #f8fafc; color: #334155; padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; font-weight: 600;">Products</a>
            <a href="/admin/orders"
              style="background: #f8fafc; color: #334155; padding: 0.55rem 0.75rem; border-radius: 10px; text-decoration: none; font-weight: 600;">Orders</a>
          </nav>
        </aside>

        <section style="flex: 1;">
          <div class="section-head"
            style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end;">
            <div>
              <h1 style="font-size: 2.2rem; color: #111827; margin-bottom: 0.5rem;">Admin Dashboard</h1>
              <p style="color: #6b7280; font-size: 1.1rem; margin: 0;">Overview of platform activity and inventory.</p>
            </div>
            <a href="/admin/products?action=add" class="btn"
              style="background: #10b981; border-color: #10b981; color: #ffffff; font-weight: 600;">+ Add Product</a>
          </div>

          <div class="grid stat-grid"
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
            <article class="card stat-card"
              style="padding: 1.5rem; display: flex; align-items: center; border-left: 4px solid #3b82f6;">
              <div style="flex-grow: 1;">
                <p
                  style="color: #6b7280; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 0.5rem;">
                  Total Users</p>
                <h3 style="font-size: 2rem; color: #111827; margin: 0;">
                  <%= stats.users %>
                </h3>
              </div>
              <div style="font-size: 2rem; color: #93c5fd;">👥</div>
            </article>
            <article class="card stat-card"
              style="padding: 1.5rem; display: flex; align-items: center; border-left: 4px solid #10b981;">
              <div style="flex-grow: 1;">
                <p
                  style="color: #6b7280; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 0.5rem;">
                  Total Products</p>
                <h3 style="font-size: 2rem; color: #111827; margin: 0;">
                  <%= stats.products %>
                </h3>
              </div>
              <div style="font-size: 2rem; color: #6ee7b7;">📦</div>
            </article>
            <article class="card stat-card"
              style="padding: 1.5rem; display: flex; align-items: center; border-left: 4px solid #f59e0b;">
              <div style="flex-grow: 1;">
                <p
                  style="color: #6b7280; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 0.5rem;">
                  Categories</p>
                <h3 style="font-size: 2rem; color: #111827; margin: 0;">
                  <%= stats.categories %>
                </h3>
              </div>
              <div style="font-size: 2rem; color: #fcd34d;">🏷️</div>
            </article>
            <article class="card stat-card"
              style="padding: 1.5rem; display: flex; align-items: center; border-left: 4px solid #8b5cf6;">
              <div style="flex-grow: 1;">
                <p
                  style="color: #6b7280; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 0.5rem;">
                  Total Orders</p>
                <h3 style="font-size: 2rem; color: #111827; margin: 0;">
                  <%= stats.orders %>
                </h3>
              </div>
              <div style="font-size: 2rem; color: #c4b5fd;">🛒</div>
            </article>
          </div>

          <div class="grid two-col" style="gap: 2rem;">
            <section class="card" style="padding: 1.5rem;">
              <h2 style="font-size: 1.3rem; margin-bottom: 1.5rem; color: #111827;">Order Status Chart</h2>
              <div style="position: relative; height: 300px;">
                <canvas id="ordersChart" data-chart='<%- JSON.stringify(stats.ordersByStatus) %>'></canvas>
              </div>
            </section>
            <section class="card" style="padding: 1.5rem; display: flex; flex-direction: column;">
              <h2 style="font-size: 1.3rem; margin-bottom: 1.5rem; color: #111827;">Command Center</h2>
              <div class="quick-links" style="display: flex; flex-direction: column; gap: 1rem; flex-grow: 1;">
                <a href="/admin/products?action=add" class="btn"
                  style="background: #10b981; border-color: #10b981; text-align: left; padding: 1rem 1.5rem;">➕ Add
                  Product Now &rarr;</a>
                <a href="/admin/users" class="btn"
                  style="background: #f3f4f6; color: #374151; font-weight: 500; text-align: left; padding: 1rem 1.5rem;">👥
                  Manage Users &rarr;</a>
                <a href="/admin/categories" class="btn"
                  style="background: #f3f4f6; color: #374151; font-weight: 500; text-align: left; padding: 1rem 1.5rem;">🏷️
                  Manage Categories &rarr;</a>
                <a href="/admin/products" class="btn"
                  style="background: #3b82f6; border-color: #3b82f6; text-align: left; padding: 1rem 1.5rem;">📦 Manage
                  Products &rarr;</a>
                <a href="/admin/orders" class="btn"
                  style="background: #f3f4f6; color: #374151; font-weight: 500; text-align: left; padding: 1rem 1.5rem;">🛒
                  Manage Orders &rarr;</a>
              </div>
            </section>
          </div>
        </section>
      </div>
    </main>

    <style>
      @media (min-width: 1024px) {
        .dashboard-shell {
          flex-direction: row !important;
          align-items: flex-start;
        }

        .dashboard-sidebar {
          width: 260px !important;
          position: sticky;
          top: 92px;
        }
      }
    </style>

    <%- include('../partials/footer') %>