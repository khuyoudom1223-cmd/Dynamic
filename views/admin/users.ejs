<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>

<main class="shell section" style="max-width: 1200px; margin: 0 auto; padding: 2rem 1rem;">
  <div class="section-head" style="margin-bottom: 2.5rem; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1 style="font-size: 2.2rem; color: #111827; margin-bottom: 0.5rem;">User Management</h1>
      <p style="color: #6b7280; font-size: 1.1rem; margin: 0;">Manage your platform's members and assign administrative roles.</p>
    </div>
    <a href="/admin" class="btn" style="background: #f3f4f6; color: #374151; font-weight: 500; border: 1px solid #d1d5db;">&larr; Back to Dashboard</a>
  </div>

<style>
  table tbody tr:hover { background: #f8fafc !important; }
  button[type="submit"]:hover { filter: brightness(0.95); }
  select:focus { border-color: #3b82f6; outline: none; box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
</style>

