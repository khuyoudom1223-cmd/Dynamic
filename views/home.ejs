<%- include('partials/head', { title }) %>
  <%- include('partials/navbar') %>
    <style>
      @keyframes float {

        0%,
        100% {
          transform: translateY(0) rotate(0deg);
        }

        50% {
          transform: translateY(-16px) rotate(1deg);
        }
      }

      .hero-image img {
        animation: float 6s ease-in-out infinite;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.08));
      }

      .hero-image img:hover {
        transform: scale(1.04) !important;
        filter: drop-shadow(0 30px 60px rgba(37, 99, 235, 0.15));
      }

      /* Section-specific styles */
      .home-hero {
        background: radial-gradient(circle at top right, var(--brand-soft) 0%, var(--bg) 100%);
        color: var(--text);
        padding: 4rem 0;
        overflow: hidden;
      }

      .home-hero .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 3rem;
        align-items: center;
      }

      .hero-kicker {
        color: var(--brand);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
        margin-bottom: 1rem;
        display: block;
      }

      .home-hero h1 {
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
        letter-spacing: -0.04em;
        color: var(--text);
      }

      .home-hero p {
        font-size: 1.125rem;
        line-height: 1.6;
        color: var(--muted);
        margin-bottom: 2.5rem;
        max-width: 540px;
      }

      .section-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--brand);
        margin-bottom: 0.75rem;
        display: block;
      }

      .home-section-head h2 {
        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text);
        margin: 0 0 0.5rem 0;
      }

      .home-section-head p {
        color: var(--muted);
        margin: 0;
        font-size: 1.05rem;
        font-weight: 500;
      }

      .book-cards-panel {
        margin-top: 3rem;
        padding-top: 3rem;
        border-top: 1px solid var(--line);
      }

      .book-cards-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }

      @media (max-width: 640px) {
        .book-cards-grid {
          grid-template-columns: 1fr;
        }
      }


      @media (max-width: 960px) {
        .home-hero .hero-grid {
          grid-template-columns: 1fr;
          text-align: center;
          gap: 2rem;
        }

        .home-hero p {
          margin-left: auto;
          margin-right: auto;
        }

        .hero-image {
          text-align: center !important;
          order: -1;
        }

        .hero-actions {
          justify-content: center;
        }
      }
    </style>

    <main>
      <!-- ── Hero Section ─────────────────────────────────────── -->
      <section class="hero home-hero">
        <div class="shell hero-grid">
          <div class="hero-content">
            <span class="hero-kicker">Education Redefined</span>
            <h1>Unlock Your Potential with Premium Content.</h1>
            <p>From digital resources to physical books, we provide everything you need to master your craft and reach
              your goals.</p>
            <div class="hero-actions" style="display: flex; gap: 1rem;">
              <a href="/products" class="btn" style="padding: 14px 28px; font-size: 1rem; white-space: nowrap;">Explore Shop</a>
              <% if (!currentUser) { %>
                <a href="/login" class="btn-outline"
                  style="padding: 14px 28px; font-size: 1rem; border-radius: var(--radius); white-space: nowrap;">Get Started</a>
                <% } %>
            </div>
          </div>
          <div class="hero-image" style="text-align: right;">
            <img src="/uploads/1777626576628-photo_2026-04-29_20-38-16-removebg-preview.png" alt="Hero Image"
              style="border-radius: 24px; width: 100%; max-width: 650px;">
          </div>
        </div>
      </section>

      <!-- Data Preparation -->
      <% let books=[]; let otherProducts=[]; if (typeof featuredProducts !=='undefined' && featuredProducts) {
        books=featuredProducts.filter(p=> p.type === 'book');
        otherProducts = featuredProducts.filter(p => p.type !== 'book');
        }
        %>

        <!-- ── Categories Section ────────────────────────────────── -->
        <% if (typeof categories !=='undefined' && categories && categories.length> 0) {
          const freeCategories = categories.filter(c => !c.price || Number(c.price) === 0);
          const paidCategories = categories.filter(c => c.price && Number(c.price) > 0 && c.type !== 'book');
          %>

          <!-- Free Section -->
          <% if (freeCategories.length> 0) { %>
            <section class="shell section" style="padding: 5rem 0;">
              <div class="section-head home-section-head" style="margin-bottom: 3rem;">
                <h2>Start for Free</h2>
                <p>Explore our library of free study materials and tools.</p>
              </div>
              <div class="cards-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
                <% freeCategories.forEach((cat)=> { %>
                  <%- include('partials/category_card', { cat, paidCategoryIds }) %>
                    <% }) %>
              </div>
            </section>
            <% } %>

              <!-- Paid Section -->
              <% if (paidCategories.length> 0) { %>
                <section class="shell section"
                  style="padding: 5rem 0; background: var(--bg-soft); border-radius: var(--radius-lg); margin-bottom: 5rem; border: 1px solid var(--line);">
                  <div class="section-head home-section-head" style="margin-bottom: 3rem; text-align: center;">
                    <h2>Premium Learning</h2>
                    <p>Specialized courses designed by industry experts.</p>
                  </div>
                  <div class="cards-grid"
                    style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 0 2rem;">
                    <% paidCategories.forEach((cat)=> { %>
                      <%- include('partials/category_card', { cat, paidCategoryIds }) %>
                        <% }) %>
                  </div>
                </section>
                <% } %>

                  <% } %>

                    <!-- ── Books & E-Books Section ───────────────────────────── -->
                    <% const bookCategories=(typeof categories !=='undefined' && categories) ? categories.filter(c=>
                      c.type === 'book') : [];
                    %>

                    <% if (bookCategories.length > 0) { %>
                      <section class="shell section" style="padding: 5rem 0;">
                          <div class="section-head home-section-head"
                            style="margin-bottom: 3rem; display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; border-bottom: 1px solid var(--line); padding-bottom: 1.5rem;">
                            <div>
                              <h2>Featured Collection</h2>
                              <p>Curated books and e-books to enhance your knowledge.</p>
                            </div>
                            <a href="/gallery"
                              style="color: var(--brand); font-weight: 700; text-decoration: none; font-size: var(--font-sm); display: flex; align-items: center; gap: 6px; white-space: nowrap;">View All <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="3">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                              </svg></a>
                          </div>
                          <div class="cards-grid">
                            <% bookCategories.forEach((cat)=> { %>
                              <%- include('partials/category_card', { cat, paidCategoryIds }) %>
                                <% }) %>
                          </div>
                      </section>
                    <% } %>

                    <% if (typeof books !== 'undefined' && books.length > 0) { %>
                      <!-- ── Recommended for You ───────────────────────────── -->
                      <section class="shell section" style="padding: 4rem 0;">
                         <div class="section-head home-section-head" style="margin-bottom: 1.5rem;">
                            <div>
                               <h2 class="h1">Recommended for You</h2>
                               <p style="font-size: 1.1rem; color: var(--muted);">Books curated based on your interests</p>
                            </div>
                         </div>
                         
                         <div class="recommended-grid full-bleed">
                            <% books.slice(0, 6).forEach((item, index) => { 
                               const category = item.category;
                               const catPrice = (item.type === 'book' && item.price !== undefined && item.price !== null) ? Number(item.price) : ((category && category.price) ? Number(category.price) : 0);
                            %>
                               <div class="recommended-card <%= index === 0 ? 'featured' : '' %> reveal">
                                  <div class="card-media">
                                     <a href="/products/<%= item.id %>">
                                        <img src="<%= item.image || 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1200' %>" alt="<%= item.name %>">
                                     </a>
                                     <% if (index === 0) { %>
                                        <span style="position: absolute; top: 1.25rem; left: 1.25rem; background: var(--brand); color: white; padding: 6px 14px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);">Top Pick</span>
                                     <% } %>
                                  </div>
                                  <div class="card-content">
                                     <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                        <h3 style="font-size: 1.3rem; margin: 0; font-weight: 800; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                           <%= item.name %>
                                        </h3>
                                     </div>
                                     <p style="color: var(--muted); font-size: 0.95rem; line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        <%= item.description || "Master your skills with this comprehensive guide designed for professionals." %>
                                     </p>
                                     <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 1.25rem; border-top: 1px solid var(--line);">
                                        <span class="price-tag">$<%= catPrice.toFixed(2) %></span>
                                        <a href="/products/<%= item.id %>" class="btn" style="padding: 10px 22px; border-radius: 14px; font-weight: 700;">View Details</a>
                                     </div>
                                  </div>
                               </div>
                            <% }) %>
                         </div>
                      </section>

                      <section class="shell section" style="padding: 2rem 0 5rem;">
                          <div class="book-cards-panel" style="padding-top: 4rem; border-top: 1px solid var(--line);">
                            <div class="section-head home-section-head" style="margin-bottom: 2.5rem; display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem;">
                              <div>
                                <h2 class="h2">Book Cards</h2>
                                <p>Browse featured books in a compact card layout.</p>
                              </div>
                              <a href="/gallery" style="color: var(--brand); font-weight: 700; text-decoration: none; font-size: var(--font-sm); display: flex; align-items: center; gap: 6px;">View All <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7" /></svg></a>
                            </div>
                            <div class="book-cards-grid">
                              <% books.forEach((item)=> { %>
                                <% const category=item.category; const catPrice=(item.type==='book' && item.price !==undefined && item.price !==null) ? Number(item.price) : ((category && category.price) ? Number(category.price) : 0); const isResource=item.type==='resource' ; const isFree=isResource || catPrice===0; const hasAccess=paidCategoryIds && category && paidCategoryIds.has(String(category.id)); %>
                                <%- include('partials/product_card_item', { item, category, catPrice, isResource, isFree, hasAccess, hidePurchaseBtn: true }) %>
                              <% }) %>
                            </div>
                          </div>
                      </section>
                    <% } %>

    </main>

    <%- include('partials/footer') %>