<style>
  /* Base Reset for Navbar */
  .purple-navbar {
    background: color-mix(in srgb, var(--bg-soft) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--text);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: all 0.3s ease;
  }

  .purple-navbar a {
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .purple-navbar .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    height: 72px;
  }

  .purple-navbar .nav-logo {
    font-size: 22px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--brand) !important;
    letter-spacing: -0.02em;
  }
  
  .purple-navbar .nav-logo svg path {
    stroke: var(--brand);
  }

  /* Center Links */
  .purple-navbar .nav-links {
    display: flex;
    gap: 8px;
    height: 100%;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .purple-navbar .nav-item {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .purple-navbar .nav-item>a {
    font-weight: 600;
    font-size: 15px;
    padding: 8px 16px;
    border-radius: 999px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .purple-navbar .nav-item:hover>a {
    color: var(--brand);
    background: var(--brand-soft);
  }

  /* Mega Dropdown Panel */
  .mega-menu {
    position: absolute;
    top: 72px;
    left: 0;
    width: 100%;
    background: var(--surface);
    color: var(--text);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-top: 1px solid var(--line);
    pointer-events: none;
  }

  .nav-item:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Mega Menu Layout */
  .mega-menu-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    gap: 48px;
  }

  /* Left Column: Info */
  .mega-menu-info h3 {
    color: var(--brand);
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 12px 0;
  }

  .mega-menu-info p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .btn-explore {
    display: inline-block;
    padding: 10px 20px;
    background: var(--brand);
    color: #fff !important;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .btn-explore:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    opacity: 0.9;
  }

  /* Middle Column: Links */
  .mega-menu-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
    align-content: start;
  }

  .mega-menu-links a {
    color: var(--text) !important;
    font-weight: 500;
    font-size: 14px;
    padding: 10px 14px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    transition: all 0.2s ease;
  }

  .mega-menu-links a:hover {
    background: var(--brand-soft);
    color: var(--brand) !important;
    transform: translateX(4px);
  }

  /* Right Column: Image */
  .mega-menu-image {
    width: 100%;
    height: 100%;
    min-height: 200px;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    background: var(--bg);
  }

  .mega-menu-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .nav-item:hover .mega-menu-image img {
    transform: scale(1.05);
  }

  /* Right Side Tools */
  .nav-tools {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .auth-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .auth-links a {
    font-weight: 600;
    font-size: 14px;
  }

  .btn-register {
    padding: 9px 20px;
    background: var(--brand);
    color: #fff !important;
    border-radius: var(--radius);
    font-weight: 600;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .btn-register:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    opacity: 0.9;
  }

  .btn-login {
    padding: 8px 18px;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: var(--text) !important;
    border-radius: var(--radius);
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-login:hover {
    border-color: var(--brand);
    color: var(--brand) !important;
    background: var(--brand-soft);
  }

  /* Hamburger Menu */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    font-size: 24px;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
  }

  .nav-toggle:hover {
    background: var(--bg);
  }

  .mobile-actions {
    display: none;
    align-items: center;
    gap: 12px;
  }

  .mobile-login-btn {
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: var(--text) !important;
    border-radius: 10px;
    padding: 6px 14px;
    font-weight: 600;
    font-size: 13px;
  }

  /* Mobile Responsive */
  @media (max-width: 992px) {
    .mobile-actions {
      display: flex;
    }

    .purple-navbar .nav-links {
      position: absolute;
      top: 72px;
      left: 0;
      width: 100%;
      height: calc(100vh - 72px);
      background: var(--surface);
      display: none;
      grid-template-columns: 1fr;
      grid-auto-rows: min-content;
      gap: 12px;
      padding: 24px;
      overflow-y: auto;
      align-content: start;
      border-top: 1px solid var(--line);
    }

    .purple-navbar .nav-links.active {
      display: grid;
    }

    .purple-navbar .nav-item {
      height: auto;
      display: block;
      width: 100%;
    }

    .purple-navbar .nav-item>a,
    .purple-navbar .nav-item form button {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      text-align: left;
      gap: 16px;
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      width: 100%;
      height: auto;
      cursor: pointer;
    }

    .purple-navbar .nav-item form {
      width: 100%;
      margin: 0;
    }

    .purple-navbar .nav-item form button {
      background: color-mix(in srgb, var(--error) 10%, var(--bg));
      color: var(--error);
      border-color: color-mix(in srgb, var(--error) 20%, var(--line));
    }

    .nav-toggle {
      display: block;
    }

    .nav-tools {
      display: none;
    }

    .mega-menu {
      position: static;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      display: none;
      background: var(--bg);
      border-radius: 12px;
      margin-top: 8px;
      border-top: none;
      padding: 16px;
    }

    .nav-item.mobile-expanded .mega-menu {
      display: block;
    }

    .mega-menu-content {
      grid-template-columns: 1fr;
      padding: 0;
      gap: 16px;
    }

    .mega-menu-info h3 {
      font-size: 18px;
      margin-bottom: 4px;
    }

    .mega-menu-info p {
      font-size: 14px;
      margin-bottom: 16px;
    }

    .mega-menu-links {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .mega-menu-links a {
      background: var(--surface);
      border-radius: 8px;
      padding: 12px;
      font-size: 14px;
    }

    .btn-explore {
      width: 100%;
      text-align: center;
    }

    .nav-icon {
      width: 24px;
      height: 24px;
      stroke: var(--brand);
      fill: none;
      stroke-width: 2;
    }

    .purple-navbar .nav-item.mobile-expanded>a {
      background: var(--brand-soft);
      border-color: var(--brand);
      color: var(--brand);
    }
  }

  @media (min-width: 993px) {
    .nav-icon {
      display: none;
    }
  }
</style>

<header class="purple-navbar site-header">
  <div class="nav-container">
    <!-- Left: Logo -->
    <a href="/" class="nav-logo">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="white" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" />
        <path d="M2 17L12 22L22 17" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M2 12L12 17L22 12" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      EngLearn
    </a>

    <!-- Center: Navigation Links -->
    <div class="mobile-actions">
      <% if (!currentUser) { %>
        <a href="/login" class="mobile-login-btn">Login</a>
        <% } %>
          <button class="nav-toggle" id="mobile-menu-btn" aria-label="Toggle Menu">
            ☰
          </button>
    </div>

    <ul class="nav-links" id="main-nav-links">
      <!-- Mega Dropdown 1: Free Resources -->
      <li class="nav-item has-mega-menu">
        <a href="#" class="mega-menu-trigger">
          <svg class="nav-icon" viewBox="0 0 24 24">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
          </svg>
          Free resources
        </a>
        <div class="mega-menu">
          <div class="mega-menu-content">
            <!-- Col 1: Info -->
            <div class="mega-menu-info">
              <h3>Free resources</h3>
              <p>Find learning materials at your English level.</p>
              <a href="/free-resources" class="btn-explore">Explore all free resources</a>
            </div>
            <!-- Col 2: Links -->
            <div class="mega-menu-links">
              <% (navCategories || []).filter(c=> c.type === 'resource' || (!c.type && (!c.price || c.price ===
                0))).forEach(cat => { %>
                <a href="/products?category=<%= cat._id %>&filter=free">
                  <%= cat.name %>
                </a>
                <% }) %>
            </div>
            <!-- Col 3: Image -->
            <div class="mega-menu-image">
              <img
                src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                alt="Students studying with free resources">
            </div>
          </div>
        </div>
      </li>

      <!-- Mega Dropdown 2: Online Courses -->
      <li class="nav-item has-mega-menu">
        <a href="#" class="mega-menu-trigger">
          <svg class="nav-icon" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <polygon points="10 8 16 12 10 16 10 8"></polygon>
          </svg>
          Online courses
        </a>
        <div class="mega-menu">
          <div class="mega-menu-content">
            <!-- Col 1: Info -->
            <div class="mega-menu-info">
              <h3>Online courses</h3>
              <p>Learn English with an online course specially created by the British Council.</p>
              <a href="/courses" class="btn-explore">Explore all courses</a>
            </div>
            <!-- Col 2: Links -->
            <div class="mega-menu-links">
              <% (navCategories || []).filter(c=> c.type === 'course' || (!c.type && (c.price > 0))).forEach(cat => { %>
                <a href="/products?category=<%= cat._id %>&filter=premium">
                  <%= cat.name %>
                </a>
                <% }) %>
            </div>
            <!-- Col 3: Image -->
            <div class="mega-menu-image">
              <img
                src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                alt="Student taking an online course">
            </div>
          </div>
        </div>
      </li>

      <!-- Normal Links -->
      <li class="nav-item">
        <a href="/ielts">
          <svg class="nav-icon" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="7"></circle>
            <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
          </svg>
          IELTS preparation
        </a>
      </li>
      <li class="nav-item">
        <a href="/level-test">
          <svg class="nav-icon" viewBox="0 0 24 24">
            <line x1="18" y1="20" x2="18" y2="10"></line>
            <line x1="12" y1="20" x2="12" y2="4"></line>
            <line x1="6" y1="20" x2="6" y2="14"></line>
          </svg>
          Level test
        </a>
      </li>


      <% if (currentUser) { %>
        <li class="nav-item mobile-only-auth" style="display: none;">
          <form action="/logout" method="post">
            <button type="submit">
              <svg class="nav-icon" viewBox="0 0 24 24">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
              </svg>
              Logout
            </button>
          </form>
        </li>
        <% } else { %>
          <li class="nav-item mobile-only-auth" style="display: none;">
            <a href="/login">
              <svg class="nav-icon" viewBox="0 0 24 24">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                <polyline points="10 17 15 12 10 7"></polyline>
                <line x1="15" y1="12" x2="3" y2="12"></line>
              </svg>
              Login
            </a>
          </li>
          <li class="nav-item mobile-only-auth" style="display: none;">
            <a href="/register">
              <svg class="nav-icon" viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="8.5" cy="7" r="4"></circle>
                <line x1="20" y1="8" x2="20" y2="14"></line>
                <line x1="23" y1="11" x2="17" y2="11"></line>
              </svg>
              Register
            </a>
          </li>
          <% } %>
    </ul>

    <!-- Right: Tools -->
    <div class="nav-tools">

      <div class="auth-links">
        <% if (currentUser) { %>
          <% if (currentUser.role==='admin' ) { %>
            <a href="/admin" class="btn-login">Dashboard</a>
            <% } else { %>
              <a href="/orders/my" class="btn-login">My Purchases</a>
              <% } %>
                <form action="/logout" method="post" style="display:inline;">
                  <button type="submit" class="btn-register">Logout</button>
                </form>
                <% } else { %>
                  <a href="/login" class="btn-login">Login</a>
                  <a href="/register" class="btn-register">Register</a>
                  <% } %>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const navLinks = document.getElementById('main-nav-links');

  mobileMenuBtn.addEventListener('click', function () {
    const isActive = navLinks.classList.toggle('active');

    // Toggle between hamburger and close icon
    this.innerHTML = isActive ? '✕' : '☰';
    this.style.transform = isActive ? 'rotate(90deg)' : 'rotate(0deg)';
    this.style.transition = 'transform 0.3s ease';

    // Toggle mobile auth links visibility

    const mobileAuths = document.querySelectorAll('.mobile-only-auth');
    mobileAuths.forEach(el => {
      el.style.display = isActive ? 'flex' : 'none';
    });

    // Prevent body scroll when menu is open
    document.body.style.overflow = isActive ? 'hidden' : '';
  });

  // Mobile mega menu accordion toggle
  document.querySelectorAll('.mega-menu-trigger').forEach(trigger => {
    trigger.addEventListener('click', function (e) {
      if (window.innerWidth <= 992) {
        e.preventDefault();
        const parentLi = this.parentElement;
        const isExpanded = parentLi.classList.toggle('mobile-expanded');

        // Rotate arrow indicator
        this.style.setProperty('--arrow-rotation', isExpanded ? '180deg' : '0deg');
      }
    });
  });
</script>