<article class="card product-card"
  style="display: flex; flex-direction: column; overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--line); padding: 0; background: var(--surface);">
  <div class="product-media"
    style="position: relative; height: 200px; overflow: hidden; background: var(--bg); padding: 0; margin: 0;">
    <a href="/products/<%= item.id %>" style="display: block; width: 100%; height: 100%;">
      <img src="<%= item.image || 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1200' %>"
        alt="<%= item.name || item.title %>"
        style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 0;" />
    </a>
    <% if (isFree) { %>
      <span
        style="position: absolute; top: 1rem; right: 1rem; background: var(--success); color: white; padding: 4px 12px; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">Free
        Access</span>
      <% } else if (hasAccess) { %>
        <span
          style="position: absolute; top: 1rem; right: 1rem; background: var(--brand); color: white; padding: 4px 12px; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);">Unlocked</span>
        <% } %>
  </div>
  <div style="padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
      <div style="display: flex; flex-direction: column; gap: 4px;">
        <p class="tag"
          style="margin: 0; font-size: 0.7rem; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">
          <%= category ? category.name : 'General' %>
        </p>
        <% if (item.type && item.type !=='course' ) { %>
          <span
            style="background: var(--brand-soft); color: var(--brand); padding: 2px 8px; border-radius: 8px; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; width: fit-content; border: 1px solid color-mix(in srgb, var(--brand) 15%, transparent);">
            <%= item.type.replace('_', ' ' ) %>
          </span>
          <% } %>
      </div>
      <div style="text-align: right;">
        <% if (hasAccess) { %>
          <span
            style="background: var(--brand-soft); color: var(--brand); padding: 4px 10px; border-radius: 999px; font-size: 0.7rem; font-weight: 700; display: block; border: 1px solid color-mix(in srgb, var(--brand) 15%, transparent);">✓
            Unlocked</span>
          <% } else if (isFree) { %>
            <span
              style="color: var(--success); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; background: color-mix(in srgb, var(--success) 10%, transparent); padding: 4px 10px; border-radius: 999px;">Free</span>
            <% } else if ((typeof hidePurchaseBtn === 'undefined' || !hidePurchaseBtn) || item.type === 'book') { %>
              <div style="display: flex; flex-direction: column; align-items: flex-end;">
                <span
                  style="background: color-mix(in srgb, var(--error) 8%, transparent); color: var(--error); padding: 4px 10px; border-radius: 999px; font-size: 0.85rem; font-weight: 800; display: block; border: 1px solid color-mix(in srgb, var(--error) 15%, transparent);">$<%= catPrice.toFixed(2) %></span>
                <span
                  style="color: var(--muted); font-size: 0.6rem; text-transform: uppercase; font-weight: 700; margin-top: 4px; letter-spacing: 0.05em;">One-time</span>
              </div>
              <% } %>
      </div>
    </div>

    <h3 style="margin: 0 0 0.5rem 0; font-size: 1.2rem; font-weight: 800; line-height: 1.3;">
      <a href="/products/<%= item.id %>" style="color: var(--text); text-decoration: none; transition: color 0.2s;">
        <%= item.name || item.title %>
      </a>
    </h3>
    <p style="color: var(--muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 1.5rem; flex-grow: 1;">
      <%= (item.description || "" ).slice(0, 85) %><%= (item.description && item.description.length> 85) ? '...' : '' %>
    </p>

    <div
      style="display: flex; flex-direction: column; gap: 1rem; border-top: 1px solid var(--line); padding-top: 1.25rem; margin-top: auto;">
      <% if (hasAccess || isFree) { %>
        <a href="/products/<%= item.id %>" class="btn"
          style="width: 100%; text-align: center; background: var(--text); color: var(--surface); font-weight: 700; border-radius: var(--radius); padding: 12px;">
          <% if (item.type==='book' ) { %>
            Read Now
            <% } else if (item.type==='resource' ) { %>
              View Resource
              <% } else if (item.type==='level_test' ) { %>
                Take Test
                <% } else { %>
                  Watch Now
                  <% } %>
        </a>
        <% } else if (typeof hidePurchaseBtn !== 'undefined' && hidePurchaseBtn) { %>
          <a href="/products/<%= item.id %>" class="btn-outline"
            style="width: 100%; text-align: center; font-weight: 700; border-radius: var(--radius); padding: 14px; border-width: 2px; white-space: nowrap; display: flex; align-items: center; justify-content: center;">
            View Details
          </a>
        <% } else { %>
          <div id="purchase-container-<%= item.id %>" style="display: flex; flex-direction: column; gap: 0.75rem;">

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                  <span style="font-size: 0.7rem; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                    Collection Access:
                  </span>
                  <span id="total-<%= item.id %>" style="font-weight: 900; font-size: 1.5rem; color: var(--text); letter-spacing: -0.02em;">$<%=
                      catPrice.toFixed(2) %></span>
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                  <button class="btn btn-buy-khqr" type="button"
                    onclick="khqrCheckout.startPayment('<%= category ? category.id : item.id %>', '<%= catPrice %>', this)"
                    style="width: 100%; background: var(--text); color: var(--surface); border: none; font-weight: 700; padding: 12px; border-radius: var(--radius); cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                    <%= item.type==='book' ? 'Buy with KHQR' : 'Unlock Collection' %>
                  </button>
                </div>
          </div>
          <% } %>
    </div>
  </div>
</article>