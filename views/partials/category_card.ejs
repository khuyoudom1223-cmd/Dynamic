<% const isCatFree=!cat.price || Number(cat.price)===0; const hasCatAccess=typeof paidCategoryIds !=='undefined' &&
  paidCategoryIds && paidCategoryIds.has(String(cat.id)); const catType=cat.type || 'course' ; %>
  <a href="/products?category=<%= cat.id %>" style="text-decoration: none; display: block; height: 100%;">
    <div class="card category-card"
      style="display: flex; flex-direction: column; height: 100%; padding: 1.75rem; border-radius: var(--radius-lg); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--line); background: var(--surface); text-align: left; position: relative; overflow: hidden; box-shadow: var(--shadow-sm);">
      <div style="position: absolute; top: 0; right: 0; padding: 1rem;">
        <span
          style="background: var(--bg); color: var(--muted); padding: 4px 12px; border-radius: 999px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; border: 1px solid var(--line); letter-spacing: 0.05em;">
          <%= catType.replace('_', ' ' ) %>
        </span>
      </div>

      <div
        style="margin-bottom: 1.5rem; border-radius: var(--radius); overflow: hidden; background: var(--bg); height: 160px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--line);">
        <% if (cat.image) { %>
          <img src="<%= cat.image %>" alt="<%= cat.name %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);" />
          <% } else { %>
            <div style="font-size: 3rem; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));">
              <%= catType==='resource' ? '📚' : catType==='ielts' ? '📝' : catType==='level_test' ? '🎯' : '🎬' %>
            </div>
            <% } %>
      </div>

      <h3 style="margin: 0 0 0.75rem 0; color: var(--text); font-size: 1.4rem; font-weight: 800; line-height: 1.2; letter-spacing: -0.02em;">
        <%= cat.name %>
      </h3>

      <div
        style="margin-top: auto; padding-top: 1.25rem; display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--line);">
        <p style="margin: 0; font-weight: 800; color: var(--brand); font-size: 1.1rem;">
          <% if (hasCatAccess) { %>
            <span style="color: var(--success);">Unlocked</span>
            <% } else if (isCatFree) { %>
              <span style="color: var(--success);">Free</span>
              <% } else { %>
                $<%= Number(cat.price).toFixed(2) %>
                  <% } %>
        </p>
        <span style="color: var(--brand); font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 4px;">Browse <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      </div>
    </div>
  </a>