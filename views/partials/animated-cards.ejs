<!-- Animated Cards Component -->
<div class="animated-cards-container">
  <div class="cards-scroll-wrapper">
    <!-- Card 1 -->
    <div class="card card-item" data-index="0">
      <div class="card-image" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
      <div class="card-content">
        <h3 class="card-title">Premium Experience</h3>
        <p class="card-description">Discover amazing features designed for you</p>
        <button class="card-button">Learn More</button>
      </div>
      <div class="card-shine"></div>
    </div>

    <!-- Card 2 -->
    <div class="card card-item" data-index="1">
      <div class="card-image" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);"></div>
      <div class="card-content">
        <h3 class="card-title">Fast & Reliable</h3>
        <p class="card-description">Lightning-fast performance you can trust</p>
        <button class="card-button">Explore</button>
      </div>
      <div class="card-shine"></div>
    </div>

    <!-- Card 3 -->
    <div class="card card-item" data-index="2">
      <div class="card-image" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);"></div>
      <div class="card-content">
        <h3 class="card-title">Innovation Hub</h3>
        <p class="card-description">Stay ahead with cutting-edge technology</p>
        <button class="card-button">Discover</button>
      </div>
      <div class="card-shine"></div>
    </div>

    <!-- Card 4 -->
    <div class="card card-item" data-index="3">
      <div class="card-image" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);"></div>
      <div class="card-content">
        <h3 class="card-title">24/7 Support</h3>
        <p class="card-description">We're always here to help you succeed</p>
        <button class="card-button">Contact Us</button>
      </div>
      <div class="card-shine"></div>
    </div>

    <!-- Card 5 -->
    <div class="card card-item" data-index="4">
      <div class="card-image" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);"></div>
      <div class="card-content">
        <h3 class="card-title">Easy Integration</h3>
        <p class="card-description">Seamlessly integrate with your workflow</p>
        <button class="card-button">Get Started</button>
      </div>
      <div class="card-shine"></div>
    </div>
  </div>

  <!-- Scroll Indicators -->
  <div class="scroll-indicators">
    <button class="indicator-dot active" data-slide="0"></button>
    <button class="indicator-dot" data-slide="1"></button>
    <button class="indicator-dot" data-slide="2"></button>
    <button class="indicator-dot" data-slide="3"></button>
    <button class="indicator-dot" data-slide="4"></button>
  </div>
</div>
