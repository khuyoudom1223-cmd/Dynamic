<%- include('partials/head', { title }) %>
  <%- include('partials/navbar') %>

    <main class="shell section">
      <div class="section-head">
        <h1>My Orders</h1>
        <a href="/products" class="btn-inline">Continue Shopping</a>
      </div>

      <div class="card table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Product</th>
              <th>Total Price</th>
              <th>Qty</th>
              <th>Status</th>
              <th>User</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!orders.length) { %>
              <tr>
                <td colspan="7">No orders yet.</td>
              </tr>
              <% } %>
                <% orders.forEach((order)=> { %>
                  <tr>
                    <td>
                      <%= order.id %>
                    </td>
                    <td>
                      <% if (order.product) { %>
                        <%= order.product.name || order.product.title %>
                          <% } else if (order.category) { %>
                            Category: <%= order.category.name %>
                              <% } else { %>
                                -
                                <% } %>
                    </td>
                    <td>$<%= Number(order.total_price).toFixed(2) %>
                    </td>
                    <td>
                      <%= order.qty || 1 %>
                    </td>
                    <td><span class="status-pill status-<%= order.status %>">
                        <%= order.status %>
                      </span></td>
                    <td>
                      <%= order.user ? order.user.name : '-' %>
                    </td>
                    <td>
                      <%= new Date(order.created_at).toLocaleString() %>
                    </td>
                    <td>
                      <% if (order.canWatch && order.product) { %>
                        <a class="btn-inline" href="/products/<%= order.product.id %>">Watch Video</a>
                        <% } else if (order.category && order.status==='paid' ) { %>
                          <a class="btn-inline" href="/products?category=<%= order.category.id %>">Browse Category</a>
                            <span class="hint">Pending Admin Approval</span>
                            <% } else { %>
                              <span class="hint">Locked</span>
                              <% } %>
                    </td>
                  </tr>
                  <% }) %>
          </tbody>
        </table>
      </div>
    </main>

    <%- include('partials/footer') %>