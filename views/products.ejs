<%- include('partials/head', { title }) %>
  <%- include('partials/navbar') %>

    <main class="shell section" style="padding-top: 4rem;">
      <div class="section-head" style="margin-bottom: 3.5rem; text-align: center;">
        <h1
          style="font-size: 3rem; color: var(--text); margin-bottom: 0.75rem; letter-spacing: -0.04em; font-weight: 800;">
          Explore Catalog</h1>
        <p style="color: var(--muted); font-size: 1.15rem; font-weight: 500; margin: 0;">Browsing <%=
            Number.isFinite(total) ? total : products.length %> active
            items across all categories</p>
      </div>

      <form method="get" action="/products" class="card"
        style="display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: center; padding: 1.5rem; margin-bottom: 4rem; background: var(--bg-soft); border-radius: var(--radius-lg); border: 1px solid var(--line); box-shadow: var(--shadow-sm);">
        <div style="flex-grow: 1; min-width: 250px; position: relative;">
          <input type="text" name="q" value="<%= q %>" placeholder="Search by name or description..."
            style="width: 100%; padding: 1rem 1.25rem; border: 1px solid var(--line); border-radius: var(--radius); font-size: 1rem; background: var(--surface); color: var(--text);" />
        </div>
        <div style="min-width: 200px;">
          <select name="category"
            style="width: 100%; padding: 1rem 1.25rem; border: 1px solid var(--line); border-radius: var(--radius); font-size: 1rem; background: var(--surface); color: var(--text); appearance: none;">
            <option value="">All Categories</option>
            <% categories.forEach((cat)=> { %>
              <option value="<%= cat.id %>" <%=String(categoryId)===String(cat.id) ? 'selected' : '' %>><%= cat.name %>
              </option>
              <% }) %>
          </select>
        </div>
        <button class="btn" type="submit"
          style="padding: 1rem 2.5rem; font-size: 1rem; font-weight: 700; white-space: nowrap;">Apply Filters</button>
      </form>

      <% if (typeof categoryId !=='undefined' && categoryId && typeof categories !=='undefined' && categories.length> 0)
        { %>
        <% const activeCat=categories.find(c=> String(c.id) === String(categoryId));
          if (activeCat && activeCat.type !== 'book') {
          const isCatFree = !activeCat.price || Number(activeCat.price) === 0;
          const hasCatAccess = typeof paidCategoryIds !== 'undefined' && paidCategoryIds &&
          paidCategoryIds.has(String(activeCat.id));
          %>
          <section class="card"
            style="margin-bottom: 4rem; padding: 2.5rem; background: radial-gradient(circle at top right, var(--brand-soft) 0%, var(--surface) 100%); border: 1px solid var(--line); border-radius: var(--radius-lg); position: relative; overflow: hidden;">
            <div
              style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; background: var(--brand); opacity: 0.05; border-radius: 50%;">
            </div>

            <div
              style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 2.5rem; position: relative; z-index: 1;">
              <div style="flex: 1; min-width: 300px;">
                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                  <span
                    style="background: var(--brand); color: white; padding: 4px 12px; border-radius: 6px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Collection</span>
                  <h2
                    style="font-size: 2rem; margin: 0; color: var(--text); font-weight: 800; letter-spacing: -0.02em;">
                    <%= activeCat.name %>
                  </h2>
                </div>
                <p
                  style="color: var(--muted); margin-bottom: 0; font-size: 1.1rem; line-height: 1.6; max-width: 600px;">
                  <% if (hasCatAccess) { %>
                    🎉 Full access granted! Explore all materials in this collection anytime.
                    <% } else if (isCatFree) { %>
                      🔓 Open access collection. Enjoy all materials for free.
                      <% } else { %>
                        Get unlimited lifetime access to all <%= products.length %> premium <%= activeCat.type==='book'
                            ? 'publications' : 'resources' %> within the <strong>
                              <%= activeCat.name %>
                            </strong> collection.
                            <% } %>
                </p>
              </div>

              <div style="text-align: right; min-width: 200px;">
                <% if (!hasCatAccess && !isCatFree) { %>
                  <div style="margin-bottom: 1.5rem;">
                    <span style="font-size: 2.5rem; font-weight: 900; color: var(--text); letter-spacing: -0.03em;">$<%=
                        Number(activeCat.price).toFixed(2) %></span>
                    <span
                      style="color: var(--muted); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-top: 4px;">Lifetime
                      Access</span>
                  </div>
                  <button class="btn" type="button"
                    onclick="khqrCheckout.startPayment('<%= activeCat.id %>', '<%= Number(activeCat.price).toFixed(2) %>', this, <%= !!locals.currentUser %>)"
                    style="padding: 1.1rem 2.5rem; font-size: 1.1rem; font-weight: 800; border-radius: var(--radius); box-shadow: 0 10px 20px color-mix(in srgb, var(--brand) 20%, transparent);">
                    Unlock Collection
                  </button>
                  <% } else { %>
                    <div
                      style="padding: 1.25rem 2rem; background: var(--brand-soft); color: var(--brand); border-radius: 16px; font-weight: 800; display: inline-flex; align-items: center; gap: 0.75rem; border: 1px solid color-mix(in srgb, var(--brand) 15%, transparent);">
                      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="3"
                        viewBox="0 0 24 24">
                        <path d="M5 13l4 4L19 7" />
                      </svg>
                      Access Unlocked
                    </div>
                    <% } %>
              </div>
            </div>
          </section>
          <% } %>
            <% } %>

              <% const books=products.filter(p=> p.type === 'book');
                const otherProducts = products.filter(p => p.type !== 'book');
                %>

                <div class="grid cards-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
                  <% if (!otherProducts.length && !books.length) { %>
                    <div
                      style="grid-column: 1/-1; text-align: center; padding: 5rem; background: var(--bg); border-radius: var(--radius-lg); border: 1px dashed var(--line); color: var(--muted);">
                      <div style="font-size: 3rem; margin-bottom: 1.5rem;">🔍</div>
                      <h3 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text);">No
                        items matched your criteria</h3>
                      <p style="margin-bottom: 2rem;">Try adjusting your filters or searching for something else.</p>
                      <a href="/products" class="btn-outline"
                        style="padding: 10px 24px; border-radius: var(--radius);">Clear All Filters</a>
                    </div>
                    <% } %>

                      <% otherProducts.forEach((item)=> { %>
                        <% const category=item.category; const catPrice=(item.type==='book' && item.price !==undefined
                          && item.price !==null) ? Number(item.price) : ((category && category.price) ?
                          Number(category.price) : 0); const isResource=item.type==='resource' ; const isFree=isResource
                          || catPrice===0; const hasAccess=paidCategoryIds && category &&
                          paidCategoryIds.has(String(category.id)); %>
                          <%- include('partials/product_card_item', { item, category, catPrice, isResource, isFree,
                            hasAccess, hidePurchaseBtn: !!categoryId }) %>
                            <% }) %>
                </div>

                <% if (books.length> 0) { %>
                  <div class="section-head"
                    style="margin-top: 6rem; margin-bottom: 2.5rem; border-top: 1px solid var(--line); padding-top: 4rem;">
                    <h2
                      style="font-size: 2.25rem; font-weight: 800; color: var(--text); margin-bottom: 0.5rem; letter-spacing: -0.03em;">
                      Books & E-Books</h2>
                    <p style="color: var(--muted); font-size: 1.1rem; font-weight: 500; margin: 0;">Explore our premium
                      collection of educational guides and resources.</p>
                  </div>
                  <div class="grid cards-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
                    <% books.forEach((item)=> { %>
                      <% const category=item.category; const catPrice=(item.type==='book' && item.price !==undefined &&
                        item.price !==null) ? Number(item.price) : ((category && category.price) ?
                        Number(category.price) : 0); const isResource=item.type==='resource' ; const isFree=isResource
                        || catPrice===0; const hasAccess=paidCategoryIds && category &&
                        paidCategoryIds.has(String(category.id)); %>
                        <%- include('partials/product_card_item', { item, category, catPrice, isResource, isFree,
                          hasAccess, hidePurchaseBtn: !!categoryId }) %>
                          <% }) %>
                  </div>
                  <% } %>

                    <% if (pageCount> 1) { %>
                      <div class="pagination"
                        style="display: flex; justify-content: center; gap: 0.75rem; margin-top: 5rem;">
                        <% for (let i=1; i <=pageCount; i++) { %>
                          <a class="pagination-link <%= i === page ? 'active' : '' %>"
                            href="/products?page=<%= i %>&q=<%= encodeURIComponent(q || '') %>&category=<%= categoryId %>">
                            <%= i %>
                          </a>
                          <% } %>
                      </div>
                      <% } %>
    </main>

    <style>
      .pagination-link {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        border: 1px solid var(--line);
        background: var(--surface);
        color: var(--text);
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .pagination-link.active {
        border-color: var(--brand);
        background: var(--brand);
        color: white;
        box-shadow: 0 4px 12px color-mix(in srgb, var(--brand) 25%, transparent);
      }

      .pagination-link:hover:not(.active) {
        border-color: var(--brand);
        color: var(--brand);
        background: var(--brand-soft);
        transform: translateY(-2px);
      }
    </style>

    <%- include('partials/footer') %>