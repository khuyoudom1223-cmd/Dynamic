# Server Port (Vercel always uses its assigned port)
PORT=3000

# Session & Authentication Secrets (generate with: openssl rand -hex 32)
SESSION_SECRET=change-this-session-secret
JWT_SECRET=change-this-jwt-secret

# Database Configuration
# Local development: mongodb://127.0.0.1:27017
# Vercel/Production: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://khuyoudom1223_db_user:KquS3EUymAlDL8ww@cluster0.0rbx2ue.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=dynamics_node

# MongoDB Connection Timeout (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Admin User (created on first startup if doesn't exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
